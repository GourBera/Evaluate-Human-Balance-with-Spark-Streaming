# =============================================================
# STEDI Streaming Project – Root Environment Variables
# =============================================================
# This file is used by docker-compose.  Copy to .env and
# fill in real values.  This file IS tracked by git as an
# example only – do NOT put real secrets here.
# =============================================================

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=notreally
REDIS_DB=0

# Kafka
KAFKA_BROKER=kafka:19092
KAFKA_EXTERNAL_PORT=9092
ZOOKEEPER_PORT=2181

# Kafka Topics
KAFKA_TOPIC_REDIS=redis-server
KAFKA_TOPIC_STEDI_EVENTS=stedi-events
KAFKA_TOPIC_CUSTOMER_RISK=customer-risk
KAFKA_TOPIC_RAPID_STEP_RISK=rapid-step-risk

# STEDI Graph UI
STEDI_GRAPH_PORT=3000

# Spark
SPARK_MASTER_PORT=7077
SPARK_MASTER_UI_PORT=8080
SPARK_WORKER_UI_PORT=8081
